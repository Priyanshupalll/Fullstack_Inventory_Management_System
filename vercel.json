{
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/products(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/customers(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/orders(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
